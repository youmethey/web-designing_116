<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Princess Wallpaper Gallery</title>
  <style>
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      margin: 0;
      background: linear-gradient(135deg, #f5c5ff 0%, #f8d5eb 40%, #e3acf9 100%);
      color: #4b2a65;
    }
    header {
      background: linear-gradient(135deg, #ffc6e1 0%, #ff9ce5 50%, #9866f0 100%);
      color: #ffffff;
      padding: 20px;
      text-align: center;
      box-shadow: inset 0 -3px 8px rgba(0,0,0,0.15);
    }
    header h1 {
      margin: 0;
      font-size: 2.2rem;
      letter-spacing: 1px;
      text-shadow: 0 2px 5px rgba(119, 46, 112, 0.5);
    }
    header p {
      margin: 5px 0 0;
      font-size: 1.1rem;
    }
    .gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 15px;
      padding: 20px;
      max-width: 1200px;
      margin: 0 auto;
    }
    .gallery img {
      width: 100%;
      height: auto;
      border-radius: 16px;
      border: 2px solid rgba(255,255,255,0.45);
      box-shadow: 0 8px 15px rgba(154, 110, 212, 0.35);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      background: linear-gradient(45deg, rgba(255,255,255,0.2), rgba(255,255,255,0));
    }
    .gallery img:hover {
      transform: scale(1.04);
      box-shadow: 0 12px 24px rgba(158, 96, 231, 0.45);
    }
    footer {
      background: #9b5fbf;
      color: #ffffff;
      text-align: center;
      padding: 14px 10px;
      margin-top: 20px;
      font-size: 0.95rem;
    }
  </style>
</head>
<body>
  <header>
    <h1>Princess Wallpaper Gallery</h1>
    <p>Enchanting princes and glittery royal wallpapers</p>
  </header>

  <section class="gallery">
    <img src="https://img.freepik.com/premium-photo/woman-sits-purple-purple-poster-that-says-god_939492-76458.jpg" alt="Princess Wallpaper 1">
    <img src="https://images.stockcake.com/public/3/0/a/30afe9e1-12a8-42f6-9167-0ebaa13bcd36/celestial-stardust-beauty-stockcake.jpg" alt="Princess Wallpaper 2">
    <img src="https://i.pinimg.com/1200x/99/b6/98/99b6988a4011ae4c75ed8fe16cf231ac.jpg" alt="Princess Wallpaper 3">
    <img src="https://png.pngtree.com/thumb_back/fh260/background/20250718/pngtree-silhouette-of-a-woman-with-galaxy-like-hair-swirling-purples-and-image_17622676.webp" alt="Princess Wallpaper 4">
    <img src="https://png.pngtree.com/thumb_back/fh260/background/20250929/pngtree-cosmic-goddess-portrait-with-starry-galaxy-hair-dreamy-fantasy-art-image_19706930.webp" alt="Princess Wallpaper 5">
    <img src="https://t4.ftcdn.net/jpg/13/60/94/75/360_F_1360947554_E0tCkAfbDNc89gMZS340TQOiMgE1zhJb.jpg" alt="Princess Wallpaper 6">
    <img src="https://t4.ftcdn.net/jpg/09/23/91/95/360_F_923919589_NBuOEW34U6rUKM72LU67L8bgSXfzJ1hY.jpg" alt="Glittery Princess 7">
    <img src="https://freepngimg.com/thumb/space/7-2-space-png-image.png" alt="Glittery Princess 8">
  </section>

  <footer>
    <p>&copy; 2026 Wallpaper Gallery. All rights reserved.</p>
  </footer>
</body>
</html>
